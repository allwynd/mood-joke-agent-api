# ─── Server ────────────────────────────────────────────────────────────────
PORT=YOUR_PORT_NUMBER

# Which provider to use: anthropic | openai | gemini
LLM_PROVIDER=YOUR_LLM_PROVIDER

# Model override per provider (each has a sensible default if omitted)
ANTHROPIC_MODEL=YOUR_ANTHROPIC_MODEL
OPENAI_MODEL=YOUR_OPENAI_MODEL
GEMINI_MODEL=YOUR_GEMINI_MODEL

# ─── AI Agent ──────────────────────────────────────────────────────────────
# Required: your Anthropic API key
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY


# ─── Joke Store ─────────────────────────────────────────────────────────────
# "local"  → reads from jokes.json (default, no extra setup)
# "vector" → queries a vector database (configure section below)
STORE=local

# Path to the jokes JSON file (used when STORE=local)
# Defaults to ./jokes.json if not set
#JOKES_FILE=.input_files/jokes.json

# ─── Vector DB (only needed when STORE=vector) ──────────────────────────────
# Which vector DB to use: "pinecone" | "qdrant"
VECTOR_PROVIDER=YOUR_VECTOR_PROVIDER

# Name of the index / collection in your vector DB
VECTOR_INDEX_NAME=mood-jokes

# ── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=YOUR_QDRANT_URL

# ─── Embedding provider (used by indexJokes.js and VectorStore) ─────────────
OPENAI_API_KEY=
